# ============================================================
# Disable ModSecurity to fix 406 errors for Bingbot
# ============================================================
<IfModule mod_security.c>
  SecFilterEngine Off
  SecFilterScanPost Off
  SecRuleEngine Off
</IfModule>

# ============================================================
# Core Rewrite Engine
# ============================================================
AddDefaultCharset UTF-8

# ============================================================
# Security Headers
# ============================================================
<IfModule mod_headers.c>
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    Header set Content-Security-Policy "default-src 'self' https: data: 'unsafe-inline' 'unsafe-eval';"
    Header set X-Content-Type-Options "nosniff"
</IfModule>

RewriteEngine On
RewriteBase /

# Force non-www to www (canonical domain)
RewriteCond %{HTTP_HOST} ^adbkanvas\.com$ [NC]
RewriteRule ^(.*)$ https://www.adbkanvas.com/$1 [R=301,L]

# Custom 404 Error Page
ErrorDocument 404 /404.html

# ============================================================
# Canonical Duplicate Fixes (Strip tracking params & /index)
# ============================================================

# Redirect /index or /index.html to homepage (only if explicitly requested)
RewriteCond %{THE_REQUEST} \s/index(\.html?)?\s [NC]
RewriteRule ^index(\.html)?$ https://www.adbkanvas.com/ [R=301,L]

# Strip Facebook tracking parameter (fbclid) - redirect to clean URL
RewriteCond %{QUERY_STRING} (^|&)fbclid= [NC]
RewriteRule ^(.*)$ https://www.adbkanvas.com/$1? [R=301,L]

# Strip LinkedIn tracking parameter (trk) - redirect to clean URL
RewriteCond %{QUERY_STRING} (^|&)trk= [NC]
RewriteRule ^(.*)$ https://www.adbkanvas.com/$1? [R=301,L]

# ============================================================
# Optimized 301 Redirects (One-Hop SEO)
# Move specific redirects here to catch HTTP requests before force rules
# ============================================================

# # Policy & Info Pages (Old names to New)
RewriteRule ^Mandarmani_Servii?ces(\.html)?/?$ https://www.adbkanvas.com/mandarmani/mandarmani-services.html [R=301,L,NC]
RewriteRule ^Mandarmani_Activities(\.html)?/?$ https://www.adbkanvas.com/mandarmani/mandarmani-activities.html [R=301,L,NC]
RewriteRule ^Lataguri_Activities(\.html)?/?$ https://www.adbkanvas.com/lataguri/lataguri-activities.html [R=301,L,NC]
RewriteRule ^Lataguri_Services(\.html)?/?$ https://www.adbkanvas.com/lataguri/lataguri-services.html [R=301,L,NC]
RewriteRule ^Terms(\.html)?/?$ https://www.adbkanvas.com/terms-and-conditions.html [R=301,L,NC]
RewriteRule ^Privacy(\.html)?/?$ https://www.adbkanvas.com/privacy-policy.html [R=301,L,NC]
RewriteRule ^cancelpol(\.html)?/?$ https://www.adbkanvas.com/cancellation-policy.html [R=301,L,NC]
RewriteRule ^aboutus(\.html)?/?$ https://www.adbkanvas.com/about-us.html [R=301,L,NC]

# OLD ROOT-LEVEL redirects -> NEW FOLDER paths (301 for SEO continuity)
RewriteRule ^mandarmani\.html$ https://www.adbkanvas.com/mandarmani/mandarmani.html [R=301,L,NC]
